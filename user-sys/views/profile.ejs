<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-slate-50 min-h-screen text-slate-800">
    
    <div class="py-10 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        
        <header class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-12">
          
          <div class="h-32 sm:h-40 bg-gradient-to-r from-indigo-500 via-purple-500 to-indigo-600"></div>
          
          <div class="px-6 sm:px-10 pb-8 relative">
            
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end -mt-16 sm:-mt-20 mb-6 z-10 relative">
              <img
                class="h-32 w-32 sm:h-40 sm:w-40 border-4 border-white rounded-full object-cover shadow-lg bg-slate-100"
                src="<%= user.image %>"
                alt="<%= user.username %>"
              />  
              
              <div class="mt-4 sm:mt-0 flex flex-wrap gap-3 sm:pb-2">
                  <a href="/editprofile"> <button
                  class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 transition-all active:scale-95"
                >
                  Edit Profile
                </button></a>
                
                <a
                  href="/logout"
                  class="flex items-center rounded-lg border border-red-200 bg-white px-5 py-2 text-sm font-medium text-red-600 shadow-sm hover:bg-red-50 transition-all active:scale-95"
                >
                  <button>Logout</button>
                </a>
                <a
                  href="/post"
                  class="flex items-center rounded-lg bg-orange-500 px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-orange-600 transition-all active:scale-95"
                >
                  Create Post
                </a>
              </div>
            </div>

            <div>
              <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight"><%= user.fullname %></h1>
              <p class="text-lg text-indigo-600 font-medium mt-1"><%= user.email %></p>
            </div>

            <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-6 border-t border-slate-100 pt-8">
              <div>
                
                <p class="text-lg font-semibold text-slate-900">@<%= user.username %></p>
              </div>
              <div>
                <p class="text-lg font-semibold text-slate-900"><%= user.phone %></p>
              </div>
              <div>
                <p class="text-sm font-medium text-slate-500 mb-1">Total Posts</p>
                <p class="text-lg font-semibold text-slate-900">10</p>
              </div>
            </div>

          </div>
        </header>

        <section>
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-slate-800 tracking-tight">
              Recent Post
            </h3>

          </div>


  <% user.posts.map((data) =>{ %>
<div class="relative group">
    <article
            class="flex flex-col sm:flex-row overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm hover:shadow-md transition-shadow duration-300"
          >
            <div class="sm:w-2/5 md:w-1/3 h-48 sm:h-auto bg-slate-100 shrink-0">
              <img
                src="/uploads/<%= data.imgurl %>"
                alt="imge"
                class="h-full w-full object-cover"
              />
            </div>

            <div class="p-6 sm:p-8 flex flex-col justify-center">
              <h2 class="text-2xl font-bold text-gray-900 mb-3 leading-tight">
                <%= data.title %>
              </h2>
              <p class="text-slate-600 leading-relaxed">
                <%= data.description %>
              </p>

              </div>
          </article>
<a href="/delete/<%= data._id %>" class="text-3xl bg-red-600 w-10 h-10 rounded-full text-center text-white absolute top-2 right-2 hidden group-hover:block z-10 transition">
  &times;
</a>
</div>
  <% }) %>
          
          
        </section>

      </div>
    </div>
    
  </body>
</html>